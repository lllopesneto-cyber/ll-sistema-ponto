# Porta (Railway define automaticamente)
PORT=3001

# Segredo da sessão — troque por uma string aleatória longa em produção
SESSION_SECRET=troque-por-string-aleatoria-segura

# Caminho do banco de dados SQLite
# Em Railway/Render: aponte para um volume persistente, ex: /data/ponto.db
# Sem isso, os dados são perdidos a cada redeploy!
DB_PATH=./ponto.db

# Timezone (define no painel do Railway/Render como variável de ambiente)
TZ=America/Sao_Paulo
